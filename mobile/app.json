{
  "expo": {
    "name": "CookMate",
    "slug": "cookmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android"
    ],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fafaf9"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fafaf9"
      },
      "package": "com.cookmate.app",
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS",
        "INTERNET"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-video"
    ],
    "extra": {
      "apiBaseUrl": ""
    }
  }
}

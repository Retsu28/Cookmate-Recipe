--
-- TOC entry 220 (class 1259 OID 20615)
-- Name: users; Type: TABLE; Schema: public; Owner: postgres
--

CREATE TABLE public.users (
    id integer NOT NULL,
    email character varying(255) NOT NULL,
    password_hash character varying(255),
    full_name character varying(255) NOT NULL,
    avatar_url text,
    bio text,
    cooking_skill_level character varying(50) DEFAULT 'Beginner'::character varying,
    created_at timestamp with time zone DEFAULT CURRENT_TIMESTAMP,
    updated_at timestamp with time zone DEFAULT CURRENT_TIMESTAMP,
    role character varying(20) DEFAULT 'user'::character varying NOT NULL,
    dietary_goals text[] DEFAULT ARRAY[]::text[],
    allergies text[] DEFAULT ARRAY[]::text[],
    notifications_enabled boolean DEFAULT true,
    firebase_uid text,
    email_verified boolean DEFAULT false NOT NULL,
    deleted_at timestamp with time zone DEFAULT NULL,
    deletion_scheduled_at timestamp with time zone DEFAULT NULL,
    CONSTRAINT users_full_name_not_blank CHECK ((btrim((full_name)::text) <> ''::text))
);


ALTER TABLE public.users OWNER TO postgres;


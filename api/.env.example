# ─── CookMate API Environment Variables ───

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123
DB_NAME=Cookmate

# JWT signing secret (min 16 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Gemini AI API key (optional, for AI features)
GEMINI_API_KEY=

# AI Camera RAG grounding (default: true). When enabled, after candidate
# recipes are retrieved from PostgreSQL, a second text-only Gemini call
# selects the best recipe strictly from the retrieved candidate IDs — Gemini
# cannot invent recipes. Set to "false" to disable the grounding step and
# fall back to pure DB ranking (retrieval is still from PostgreSQL).
ENABLE_GEMINI_RAG=true
GEMINI_RAG_TIMEOUT_MS=15000

# CORS — allowed origins (comma-separated)
# Development: http://localhost:5173 (Vite), http://localhost:19006 (Expo web)
# Local Expo/LAN origins are allowed automatically when NODE_ENV is not production.
# Production: https://your-domain.com
CORS_ORIGINS=http://localhost:5173

# ── Google Sign-In (OAuth 2.0) ─────────────────────────────────────────────
# Create an OAuth Client ID (type: "Web application") in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins (dev): http://localhost:5173
# The backend verifies Google ID tokens against this Client ID.
GOOGLE_CLIENT_ID=

# ── Gmail SMTP (nodemailer) ────────────────────────────────────────────────
# Used for transactional email (password reset, notifications, etc).
# SMTP_PASS must be a Gmail App Password (not your normal Gmail password):
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CookMate <no-reply@cookmate.com>

# ── Web app base URL (used in password-reset emails) ───────────────────────
WEB_APP_URL=http://localhost:5173

# ── Hugging Face Inference API (background removal) ───────────────────────
# Free token from huggingface.co → Settings → Access Tokens (Read permission)
# Used as primary background removal strategy; falls back to @imgly local if unset or fails.
# Optional: set HF_API_TIMEOUT_MS to override the default 60s timeout.
HF_API_TOKEN=
# HF_API_TIMEOUT_MS=60000
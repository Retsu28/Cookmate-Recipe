# ─── CookMate API Environment Variables ───

# Server
PORT=5000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123
DB_NAME=Cookmate

# JWT signing secret (min 16 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Gemini AI API key for AI Camera (image analysis + RAG grounding)
GEMINI_API_KEY=

# Gemini AI API key for the AI Chatbot (separate quota/key from camera)
GEMINI_CHAT_API_KEY=

# AI Camera RAG grounding (default: true). When enabled, after candidate
# recipes are retrieved from PostgreSQL, a second text-only Gemini call
# selects the best recipe strictly from the retrieved candidate IDs — Gemini
# cannot invent recipes. Set to "false" to disable the grounding step and
# fall back to pure DB ranking (retrieval is still from PostgreSQL).
ENABLE_GEMINI_RAG=true
GEMINI_RAG_TIMEOUT_MS=15000

# CORS — allowed origins (comma-separated)
# Development: http://localhost:5173 (Vite), http://localhost:19006 (Expo web)
# Local Expo/LAN origins are allowed automatically when NODE_ENV is not production.
# Production: https://your-domain.com
CORS_ORIGINS=http://localhost:5173

# ── Google Sign-In (OAuth 2.0) ─────────────────────────────────────────────
# Create an OAuth Client ID (type: "Web application") in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins (dev): http://localhost:5173
# The backend verifies Google ID tokens against this Client ID.
GOOGLE_CLIENT_ID=

# ── Gmail SMTP (nodemailer) ────────────────────────────────────────────────
# Used for transactional email (password reset, notifications, etc).
# SMTP_PASS must be a Gmail App Password (not your normal Gmail password):
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=CookMate <no-reply@cookmate.com>

# ── Web app base URL (used in password-reset emails) ───────────────────────
WEB_APP_URL=http://localhost:5173

# ── Hugging Face Inference API (background removal) ───────────────────────
# Free token from huggingface.co → Settings → Access Tokens (Read permission)
# Used as primary background removal strategy; falls back to @imgly local if unset or fails.
# Optional: set HF_API_TIMEOUT_MS to override the default 60s timeout.
HF_API_TOKEN=
# HF_API_TIMEOUT_MS=60000

# ── ML Analytics Service ───────────────────────────────────────────────────
# FastAPI microservice running alongside Express (see ml_service/README.md)
ML_SERVICE_HOST=localhost
ML_SERVICE_PORT=8001
# Set to true in production when the ML service is behind HTTPS (e.g. Render/Railway)
# Auto-detected as true when ML_SERVICE_HOST is not localhost — set to false to override
ML_SERVICE_HTTPS=false

# ── Redis (Caching & BullMQ Queues) ──────────────────────────────────────────
# Optional — the app works without Redis (caching disabled, queues skip).
# Use REDIS_URL for managed Redis (e.g. Redis Cloud, Upstash, Railway):
#   REDIS_URL=redis://default:password@host:6379
# Or specify individual connection params:
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=cookmate:
# BullMQ worker concurrency per queue (default: 3)
BULL_CONCURRENCY=3

# ── Cloudinary (Video Uploads) ───────────────────────────────────────────────
# Get your credentials from https://cloudinary.com/console
# 1. Sign up for free at cloudinary.com
# 2. Go to Dashboard → Account Details
# 3. Copy Cloud name, API Key, and API Secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
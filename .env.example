# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-2.5-flash-lite"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Postgres Database connection settings
DB_HOST="localhost"
DB_PORT="5432"
DB_USER="postgres"
DB_PASSWORD="123"
DB_NAME="Cookmate"

# JWT signing secret for /api/auth (min 16 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# API base URL for the React web frontend.
# In development, Vite proxies /api/* to localhost:5000 so this can be left empty.
# In production, set to the EC2 API URL, e.g.: https://api.cookmate.com
VITE_API_BASE_URL=
